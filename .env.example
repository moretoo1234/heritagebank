# Heritage Bank – Environment Variables
# Copy to .env and fill in your values.
# In production (Render/etc), set these in the service dashboard.

# ── Required ──
JWT_SECRET=change_me_to_a_long_random_secret
ADMIN_PASSWORD=change_me

# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=heritage_bank

# ── Server ──
PORT=3001

# ── Production ──
# NODE_ENV=production
# PRODUCTION_ORIGIN=https://yourdomain.com
# ALLOWED_ORIGINS=https://yourdomain.com

# ── Banking ──
ROUTING_NUMBER=091238946
# ADMIN_EMAIL=admin@heritagebank.com
# ADMIN_INITIAL_BALANCE=1000000

# ── Contact Info ──
# SUPPORT_EMAIL=support@heritagebank.com
# SUPPORT_PHONE=1-800-HERITAGE
# BANK_WEBSITE=www.heritagebank.com

# ── Interest Rates (decimal form, e.g. 0.0425 = 4.25%) ──
# SAVINGS_APY=0.0425
# CHECKING_APY=0.0001

# ── Compliance / Business Rules ──
# CTR_THRESHOLD=10000
# MAX_TXN_PER_HOUR=10
# FEE_WAIVER_MIN_BALANCE=1500
# DORMANT_DAYS=365

# ── Encryption ──
# CARD_ENCRYPTION_KEY=

# ── Email (optional – enables password reset) ──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

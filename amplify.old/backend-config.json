{
  "auth": {
    "heritageauth": {
      "service": "Cognito",
      "providerPlugin": "awscloudformation",
      "dependsOn": [],
      "customAuth": false,
      "frontendAuthConfig": {
        "loginWith": {
          "email": true
        },
        "signUp": {
          "passwordRequirements": [],
          "requireEmail": true
        },
        "mfa": {
          "status": "off",
          "totpEnabled": false
        }
      },
      "userVerification": true,
      "resourceName": "heritageauth"
    }
  }
}

{
  "heritageauth": {
    "service": "Cognito",
    "providerPlugin": "awscloudformation",
    "dependsOn": [],
    "customAuth": false,
    "frontendAuthConfig": {
      "loginWith": {
        "email": true
      },
      "signUp": {
        "passwordRequirements": ["^8(?=.*[a-zA-Z])(?=.*[0-9])"],
        "requireEmail": true
      },
      "mfa": {
        "status": "off",
        "totpEnabled": false
      }
    },
    "userVerification": true,
    "outputKeyName": "CognitoUserPoolOutputs",
    "resourceName": "heritageauth",
    "uuid": "heritageauthuuid"
  }
}

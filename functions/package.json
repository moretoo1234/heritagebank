{
  "name": "heritage-bank-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Heritage Bank",
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "migrate": "node migrate-mysql-to-firestore.js",
    "migrate:local": "firebase emulators:start --only firestore & sleep 5 && node migrate-mysql-to-firestore.js"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0",
    "firebase-tools": "^15.19.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5"
  }
}

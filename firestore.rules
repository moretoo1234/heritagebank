rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin (reads from user document)
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== USERS ====================
    // Users can read their own profile, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();  // Only admins can create users
      allow update: if isOwner(userId) || isAdmin();  // Users can update themselves, admins can update anyone
      allow delete: if isAdmin();  // Only admins can delete users
      
      // Subcollections
      match /settings/{document=**} {
        allow read, write: if isOwner(userId);
      }
      
      match /credentials/{credentialId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ==================== TRANSACTIONS ====================
    match /transactions/{transactionId} {
      // Users can read transactions they're involved in; admins can read all
      allow read: if isAuthenticated() && 
        (resource.data.fromUserId == request.auth.uid || 
         resource.data.toUserId == request.auth.uid ||
         isAdmin());
      // Users can create transactions (transfers); admins can override
      allow create: if isAuthenticated();
      // Admins can update/delete transactions
      allow update, delete: if isAdmin();
    }
    
    // ==================== ACTIVITY LOGS ====================
    match /activityLogs/{logId} {
      // Users can read their own logs
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can read all logs
      allow read: if isAdmin();
      // System can write logs
      allow create: if isAuthenticated();
      // Admins can delete old logs
      allow delete: if isAdmin();
    }
    
    // ==================== LOAN APPLICATIONS ====================
    match /loanApplications/{loanId} {
      // Users can read and manage their own loans
      allow read, create, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can manage all loans
      allow read, update, delete: if isAdmin();
    }
    
    // ==================== DOCUMENTS ====================
    match /documents/{docId} {
      // Users can read and manage their own documents
      allow read, create: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can manage all documents
      allow read, update, delete: if isAdmin();
    }
    
    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // System can create notifications
      allow create: if isAuthenticated();
      // Users can mark notifications as read
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==================== SAVINGS GOALS ====================
    match /savingsGoals/{goalId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
    
    // ==================== PUBLIC DATA ====================
    // Branch locations (public read)
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ATM locations (public read)
    match /atms/{atmId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Exchange rates (public read)
    match /exchangeRates/{currencyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

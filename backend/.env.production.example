# Heritage Bank - Production Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# CRITICAL: Database Configuration
# ============================================
DB_HOST=your-database-host.com
DB_PORT=4000
DB_USER=your-db-username
DB_PASSWORD=your-secure-db-password
DB_NAME=heritage_bank

# ============================================
# CRITICAL: JWT Secret (REQUIRED in production)
# ============================================
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARACTERS

# ============================================
# Admin Account Configuration
# ============================================
ADMIN_EMAIL=admin@heritagebank.com
ADMIN_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# Optional: Database SSL
# ============================================
# Set to 'false' only if your database doesn't support SSL
# DB_SSL=true

# ============================================
# SECURITY NOTES:
# ============================================
# 1. NEVER commit this file with real values to version control
# 2. Use different secrets for development and production
# 3. Rotate JWT_SECRET periodically
# 4. Use strong passwords for ADMIN_PASSWORD
# 5. Keep this file secure with proper file permissions (chmod 600)

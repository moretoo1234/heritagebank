{
  "version": 2,
  "env": {
    "REACT_APP_API_URL": {
      "description": "Backend API URL (set to your Railway backend URL)"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
